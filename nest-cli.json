{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "apps/api",
  "sourceRoot": "apps/api/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true
  },
  "projects": {
    "api": {
      "type": "application",
      "root": "apps/api",
      "entryFile": "main",
      "sourceRoot": "apps/api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api/tsconfig.app.json"
      }
    },
    "crawler-worker": {
      "type": "application",
      "root": "apps/crawler-worker",
      "entryFile": "main",
      "sourceRoot": "apps/crawler-worker/src",
      "compilerOptions": {
        "tsConfigPath": "apps/crawler-worker/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "packages/common",
      "entryFile": "index",
      "sourceRoot": "packages/common/src",
      "compilerOptions": {
        "tsConfigPath": "packages/common/tsconfig.lib.json"
      }
    },
    "crawler": {
      "type": "library",
      "root": "packages/crawler",
      "entryFile": "index",
      "sourceRoot": "packages/crawler/src",
      "compilerOptions": {
        "tsConfigPath": "packages/crawler/tsconfig.lib.json"
      }
    },
    "db": {
      "type": "library",
