{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "apps/api",
  "sourceRoot": "apps/api/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true
  },
  "projects": {
    "api": {
      "type": "application",
      "root": "apps/api",
      "entryFile": "main",
      "sourceRoot": "apps/api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api/tsconfig.app.json"
      }
    },
    "crawler-worker": {
      "type": "application",
      "root": "apps/crawler-worker",
      "entryFile": "main",
      "sourceRoot": "apps/crawler-worker/src",
      "compilerOptions": {
        "tsConfigPath": "apps/crawler-worker/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "packages/common",
      "entryFile": "index",
      "sourceRoot": "packages/common/src",
      "compilerOptions": {
        "tsConfigPath": "packages/common/tsconfig.lib.json"
      }
    },
    "db": {
      "type": "library",
      "root": "packages/db",
      "entryFile": "index",
      "sourceRoot": "packages/db/src",
      "compilerOptions": {
        "tsConfigPath": "packages/db/tsconfig.lib.json"
      }
    },
    "discovery-sources": {
      "type": "library",
      "root": "packages/discovery-sources",
      "entryFile": "index",
      "sourceRoot": "packages/discovery-sources/src",
      "compilerOptions": {
        "tsConfigPath": "packages/discovery-sources/tsconfig.lib.json"
      }
    },
    "topic-engine": {
      "type": "library",
      "root": "packages/topic-engine",
      "entryFile": "index",
      "sourceRoot": "packages/topic-engine/src",
      "compilerOptions": {
        "tsConfigPath": "packages/topic-engine/tsconfig.lib.json"
      }
    }
  }
}
