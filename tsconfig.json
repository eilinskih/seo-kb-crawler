{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "ignoreDeprecations": "6.0",
    "incremental": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "jest"
    ],
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@seo-kb/common": [
        "packages/common/src"
      ],
      "@seo-kb/common/*": [
        "packages/common/src/*"
      ],
      "@seo-kb/content-processing": [
        "packages/content-processing/src"
      ],
      "@seo-kb/content-processing/*": [
        "packages/content-processing/src/*"
      ],
      "@seo-kb/context-pack": [
        "packages/context-pack/src"
      ],
      "@seo-kb/context-pack/*": [
        "packages/context-pack/src/*"
      ],
      "@seo-kb/chunking": [
        "packages/chunking/src"
      ],
      "@seo-kb/chunking/*": [
        "packages/chunking/src/*"
      ],
      "@seo-kb/crawler": [
        "packages/crawler/src"
      ],
      "@seo-kb/crawler/*": [
        "packages/crawler/src/*"
      ],
      "@seo-kb/db": [
        "packages/db/src"
      ],
      "@seo-kb/db/*": [
        "packages/db/src/*"
      ],
      "@seo-kb/embeddings": [
        "packages/embeddings/src"
      ],
      "@seo-kb/embeddings/*": [
        "packages/embeddings/src/*"
      ],
      "@seo-kb/entities": [
        "packages/entities/src"
      ],
      "@seo-kb/entities/*": [
        "packages/entities/src/*"
      ],
      "@seo-kb/fact-extraction": [
        "packages/fact-extraction/src"
      ],
      "@seo-kb/fact-extraction/*": [
        "packages/fact-extraction/src/*"
      ],
      "@seo-kb/knowledge-pack": [
        "packages/knowledge-pack/src"
      ],
      "@seo-kb/knowledge-pack/*": [
        "packages/knowledge-pack/src/*"
      ],
      "@seo-kb/ontology": [
        "packages/ontology/src"
      ],
      "@seo-kb/ontology/*": [
