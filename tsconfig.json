      "@seo-kb/seo-consensus": [
        "packages/seo-consensus/src"
      ],
      "@seo-kb/seo-consensus/*": [
        "packages/seo-consensus/src/*"
      ],
      "@seo-kb/demand-engine": [
        "packages/demand-engine/src"
      ],
      "@seo-kb/demand-engine/*": [
        "packages/demand-engine/src/*"
      ],
      "@seo-kb/serp-intelligence": [
        "packages/serp-intelligence/src"
      ],
      "@seo-kb/serp-intelligence/*": [
        "packages/serp-intelligence/src/*"
      ],
      "@seo-kb/serp-intent": [
        "packages/serp-intent/src"
      ],
