        "packages/long-tail-discovery/src/*"
      ],
      "@seo-kb/seo-candidate-scoring": [
        "packages/seo-candidate-scoring/src"
      ],
      "@seo-kb/seo-candidate-scoring/*": [
        "packages/seo-candidate-scoring/src/*"
      ],
      "@seo-kb/seo-pack": [
        "packages/seo-pack/src"
      ],
      "@seo-kb/seo-pack/*": [
        "packages/seo-pack/src/*"
      ],
      "@seo-kb/research-scheduling": [
        "packages/research-scheduling/src"
      ],
